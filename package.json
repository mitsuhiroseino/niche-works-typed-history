{
  "name": "@niche-works/typed-history",
  "version": "0.1.0",
  "keywords": [
    "history"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mitsuhiroseino/niche-works-typed-history.git"
  },
  "license": "MIT",
  "author": "Mitsuhiro Seino",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*/index.ts",
    "./constants": "./src/constants.ts",
    "./*/constants": "./src/*/constants.ts"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "indexes": "tsx scripts/indexes.ts",
    "test": "vitest",
    "tidy": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" --config ./prettier.tidy.config.js"
  },
  "dependencies": {
    "@niche-works/utils": "^0.1.3",
    "klona": "^2.0.6",
    "remeda": "^2.34.0",
    "tslib": "^2.8.1",
    "type-fest": "^5.6.0"
  },
  "devDependencies": {
    "@niche-works/dev": "^0.5.1",
    "@niche-works/rollup-plugin-dist-package": "^0.1.0",
    "@types/node": "^25.5.0",
    "fast-glob": "^3.3.3",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.32.1"
}
